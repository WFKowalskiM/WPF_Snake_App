<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="400">
    <Grid>
        <StackPanel>
            <Button Name="buttonPlay" Content="Play" Click="buttonPlay_Click" Width="250" Height="35" Margin="0,80,0,0"/>
            <TextBlock Name="TextBlock1" TextWrapping="Wrap" Width="168"/>
            <TextBlock Name="TextBlock2" TextWrapping="Wrap" Width="168"/>
            <Button Name="buttonCredits" Content="Credits" Click="buttonCredits_Click" Width="250" Height="35" Margin="0,50,0,0"/>
            <Button Name="buttonExit" Content="Exit" Click="buttonExit_Click" Width="250" Height="35" Margin="0,80,0,0"/>
        </StackPanel>
    </Grid>
</Window>
