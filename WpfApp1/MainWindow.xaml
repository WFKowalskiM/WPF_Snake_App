<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp"
        mc:Ignorable="d"
        Title="Snake!!!" Height="480" Width="400">
    <Grid>
        <StackPanel>
            <TextBlock Name="TextBlockMain" TextAlignment="Center" Margin="0, 20, 5, 0" Width="300" Height="80" FontFamily="Narkisim" FontSize="70" FontStyle="Oblique" Foreground="Green" FontWeight="ExtraBold" Text="SNAKE">
            </TextBlock>
            <Button Name="buttonPlay" Click="buttonPlay_Click" Width="300" Height="50" Margin="0,0,0,0" FontFamily="Lucida Sans" FontSize="30" FontWeight="Medium" Background="Green">
                <AccessText Text="Play : [_E]"/>
            </Button>
            <TextBlock Name="TextBlock1" Margin="0, 0, 0, 0" Width="115" Height="20" FontWeight="Medium" Text="Game Speed: Normal"/>
            <DockPanel>
                <Button Name="buttonNormal" Click="buttonNormal_Click" Width="100" Height="20" Margin="95,0,0,0" FontWeight="Medium" Background="Gray">
                    <AccessText Text="Normal : [_1]"/>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="DarkBlue"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Name="buttonFast" HorizontalAlignment="Right" Click="buttonFast_Click" Width="100" Height="20" Margin="0,0,95,0" FontWeight="Medium" Background="Gray">
                    <AccessText Text="Fast: [_2]"/>
                </Button>
            </DockPanel>
            <Button Name="buttonControls" Click="buttonControls_Click" Width="250" Height="40" Margin="0,30,0,0" FontSize="25" FontWeight="Medium" Background="Gray">
                <AccessText Text="Controls : [_C]"/>
            </Button>
            <Button Name="buttonCredits" Click="buttonCredits_Click" Width="250" Height="40" Margin="0,30,0,0" FontSize="25" FontWeight="Medium" Background="Gray">
                <AccessText Text="Credits : [_Z]"/>
            </Button>
            <Button Name="buttonExit" Click="buttonExit_Click" Width="250" Height="35" Margin="0,30,0,0" FontSize="25" FontWeight="Medium" Background="Gray">
                <AccessText Text="Quit : [_Q]"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
